# Anthropic Messages API. Keep the model env-driven; do not hardcode it in code.
# As of the Anthropic models overview checked during this implementation, Sonnet 4 is:
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=

# Solana / Aegis.
SOLANA_RPC_URL=http://127.0.0.1:8899
SOLANA_COMMITMENT=confirmed
AEGIS_PROGRAM_ID=7qRKV1dNPCixKWDLHsuHa5puFsNPtNCzC1sX6P1kpFgb

# API mode derives the policy PDA from the signed-in wallet. The owner address is
# still useful for scripts/bootstrap, but route authorization comes from the
# wallet session cookie.
AEGIS_OWNER_ADDRESS=

# Scoped agent keypair used to sign only Aegis `agent_transfer` instructions.
# Use either a path to a Solana keypair JSON file or a JSON/base58 secret value.
PRAXIS_AGENT_KEYPAIR_PATH=./keys/agent.json
PRAXIS_AGENT_KEYPAIR=

# Optional owner keypair for server-side policy admin routes and the local demo
# bootstrap. Omit in production if owner actions are wallet-signed elsewhere.
PRAXIS_OWNER_KEYPAIR_PATH=./keys/owner.json
PRAXIS_OWNER_KEYPAIR=

# Required for rotate-agent/re-enable. Must be different from PRAXIS_AGENT_KEYPAIR;
# the backend refuses to restore the current key by default.
PRAXIS_NEXT_AGENT_KEYPAIR_PATH=
PRAXIS_NEXT_AGENT_KEYPAIR=

# Optional frontend switch. Use `api` only after configuring the live backend.
NEXT_PUBLIC_PRAXIS_PROVIDER=mock

# Required for durable wallet sessions in production. Use a random 32+ character
# value. Local development falls back to an in-memory secret that rotates on
# process restart.
PRAXIS_SESSION_SECRET=

# State backend for API-mode threads, proposals, and rejected activity.
#   fs       - filesystem (local/devnet; not durable across serverless instances)
#   postgres - managed Postgres (production; durable across instances)
# Defaults to `postgres` when a database URL is set, otherwise `fs`.
PRAXIS_STATE_BACKEND=fs

# Local/devnet filesystem state directory (used when PRAXIS_STATE_BACKEND=fs).
PRAXIS_STATE_DIR=.praxis/state

# Managed Postgres connection string (used when PRAXIS_STATE_BACKEND=postgres).
# Neon (Vercel Marketplace) or any Postgres-compatible URL works. The schema is
# created lazily on first use; see server/provider/migrations/0001_init.sql.
# POSTGRES_URL / PRAXIS_DATABASE_URL are also accepted.
DATABASE_URL=

# Bound external dependencies so the app fails cleanly instead of hanging.
PRAXIS_LLM_TIMEOUT_MS=15000
PRAXIS_RPC_READ_TIMEOUT_MS=8000
PRAXIS_INDEXER_TIMEOUT_MS=4000

# Optional local deterministic parser for demos without an Anthropic key.
PRAXIS_LOCAL_INTENT=0
PRAXIS_DEMO_USE_CLAUDE=0

# Optional off-chain address book. Labels have no signing power.
PRAXIS_ADDRESS_BOOK=[{"label":"maya","name":"Maya Patel","address":"ALUMw7kSn9xn67suHr2ti21CXBQVNMuRk7uWSM1WuXEt","note":"saved contact"}]

# Optional indexer endpoint for research. `{mint}` is replaced at runtime.
PRAXIS_INDEXER_URL=https://api.dexscreener.com/latest/dex/tokens/{mint}
